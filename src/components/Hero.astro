---
import type { MotionPersonality } from '../motion/types';
import { motionConfigs } from '../motion/personalities';

interface Props {
  personality: MotionPersonality;
}

const { personality } = Astro.props;
const config = motionConfigs[personality];
---

<section class="relative min-h-screen flex items-center overflow-hidden">
  <!-- アンビエントレイヤー -->
  <div
    class="ambient-layer absolute inset-0 pointer-events-none"
    aria-hidden="true"
    style={`background: radial-gradient(ellipse 60% 50% at 70% 40%, color-mix(in oklch, ${config.accentColor} 12%, transparent), transparent)`}
  ></div>

  <!-- グリッド装飾（editorial感） -->
  <div class="absolute top-0 right-0 w-px h-full bg-current opacity-5" aria-hidden="true"></div>
  <div class="absolute left-8 top-1/2 -translate-y-1/2 writing-mode-vertical text-xs tracking-[0.3em] uppercase opacity-20 hidden lg:block">
    {config.label} — {config.tagline}
  </div>

  <div class="hero-content relative z-10 px-8 md:px-16 lg:px-24 max-w-6xl w-full">
    <!-- パーソナリティラベル -->
    <div class="hero-shadow mb-6 flex items-center gap-4">
      <span
        class="inline-block w-8 h-px"
        style={`background-color: ${config.accentColor}`}
      ></span>
      <span class="text-xs tracking-[0.25em] uppercase opacity-60">{config.tagline}</span>
    </div>

    <!-- メイン見出し -->
    <h1 class="text-5xl md:text-7xl lg:text-8xl leading-[1.1] mb-8 max-w-3xl" style="font-family: var(--font-display)">
      {config.heroTitle}
    </h1>

    <!-- サブコピー -->
    <p class="text-lg md:text-xl opacity-60 mb-12 max-w-lg leading-relaxed">
      同じコンテンツでも、モーションが<br />体験を変える。
    </p>

    <!-- CTA -->
    <div class="flex items-center gap-6">
      <button
        class="cta-btn relative inline-flex items-center gap-3 px-8 py-4 text-sm tracking-widest uppercase font-medium overflow-hidden"
        style={`border: 1px solid ${config.accentColor}; color: var(--color-ink)`}
      >
        <span
          class="btn-bg absolute inset-0"
          style={`background-color: ${config.accentColor}; opacity: 0; transform-origin: left center`}
        ></span>
        <span class="btn-label relative z-10">詳しく見る</span>
        <span class="btn-arrow relative z-10 inline-block">→</span>
      </button>
      <span class="text-xs opacity-30 tracking-wider">スクロールして確認</span>
    </div>
  </div>

  <!-- 大きな番号装飾 -->
  <div
    class="absolute bottom-8 right-8 text-[20vw] leading-none font-bold opacity-3 select-none pointer-events-none hidden lg:block"
    style="font-family: var(--font-display); opacity: 0.03"
    aria-hidden="true"
  >
    {config.label.charAt(0)}
  </div>
</section>

<style>
  .writing-mode-vertical {
    writing-mode: vertical-rl;
  }
</style>
