---
import type { MotionPersonality } from '../motion/types';
import { motionConfigs } from '../motion/personalities';

interface Props {
  personality: MotionPersonality;
}

const { personality } = Astro.props;
const config = motionConfigs[personality];

const items = [
  {
    number: '01',
    tag: 'パフォーマンス',
    title: 'ページ読み込みを最大60%高速化',
    body: '最適化されたアセット配信とキャッシュ戦略により、Core Web Vitalsを大幅に改善。ユーザーの離脱率を下げ、コンバージョンに直結します。LCP・CLS・INPのすべての指標でGood判定を目指した実装を提供します。',
  },
  {
    number: '02',
    tag: 'デザイン',
    title: 'ブランドに宿る一貫したモーション言語',
    body: '4つのパーソナリティ定数を切り替えるだけで、サイト全体のモーションが統一されます。デザイナーとエンジニアの協業を加速し、デザインシステムとしてのモーション管理を実現します。',
  },
  {
    number: '03',
    tag: 'アクセシビリティ',
    title: 'prefers-reduced-motion に完全対応',
    body: '前庭障害など動きに敏感なユーザーへの配慮をデフォルトで組み込み。インクルーシブなUXを標準実装します。WAI-ARIAガイドラインに沿ったマークアップで、スクリーンリーダーとの共存も確保。',
  },
  {
    number: '04',
    tag: '開発体験',
    title: 'TypeScript型安全なモーション定数',
    body: '全パーソナリティの設定値が型で保護されているため、補完が効き誤設定を防ぎます。チームの学習コストを最小化し、レビュープロセスをシンプルに保ちます。',
  },
  {
    number: '05',
    tag: 'ビジネス効果',
    title: 'モーションで滞在時間1.8倍の実績',
    body: '適切なパーソナリティのモーションを採用することで、ユーザーエンゲージメントが測定可能なレベルで向上。ROIを可視化し、次の意思決定をデータで裏付けます。',
  },
];
---

<section class="py-32 px-8 md:px-16 lg:px-24">
  <div class="max-w-6xl mx-auto">
    <!-- ヘッダー -->
    <div class="mb-16">
      <p class="text-xs tracking-[0.25em] uppercase opacity-40 mb-4">Capabilities</p>
      <h2 class="text-3xl md:text-4xl" style="font-family: var(--font-display)">
        できること
      </h2>
    </div>

    <!-- リスト -->
    <div class="divide-y divide-current/10 -mx-4 md:-mx-8">
      {items.map((item, i) => (
        <article
          class="card-list-item relative py-8 md:py-10 px-4 md:px-8 flex flex-col md:flex-row md:items-center gap-6 md:gap-10 overflow-hidden"
          data-index={i}
        >
          <!-- ホバー背景 -->
          <div
            class="card-list-bg absolute inset-0 pointer-events-none"
            style={`background-color: color-mix(in oklch, ${config.accentColor} 6%, transparent); opacity: 0`}
            aria-hidden="true"
          />
          <!-- アクセントライン (左端) -->
          <div
            class="card-list-accent absolute left-0 top-0 w-0.5 h-0 pointer-events-none"
            style={`background-color: ${config.accentColor}`}
            aria-hidden="true"
          />

          <div class="relative z-10 flex items-start md:items-center gap-6 md:gap-8 flex-1 min-w-0">
            <!-- 番号 -->
            <span class="text-xs font-mono opacity-20 flex-shrink-0 w-6 mt-1 md:mt-0">
              {item.number}
            </span>

            <!-- タグ -->
            <span
              class="hidden md:inline-block text-xs tracking-[0.15em] uppercase flex-shrink-0 w-28 opacity-60"
              style={`color: ${config.accentColor}`}
            >
              {item.tag}
            </span>

            <!-- テキスト -->
            <div class="flex-1 min-w-0">
              <h3
                class="card-list-title text-lg md:text-xl mb-2 leading-snug"
                style="font-family: var(--font-display)"
              >
                {item.title}
              </h3>
              <p class="text-sm opacity-50 leading-relaxed line-clamp-2">{item.body}</p>
            </div>
          </div>

          <!-- モーダルトリガーボタン -->
          <button
            class="modal-trigger relative z-10 flex-shrink-0 self-start md:self-center text-xs tracking-[0.15em] uppercase px-5 py-2.5 border border-current/20 hover:border-current/50 transition-colors"
            data-modal-title={item.title}
            data-modal-tag={item.tag}
            data-modal-body={item.body}
            aria-label={`${item.title}の詳細を見る`}
          >
            詳細
          </button>
        </article>
      ))}
    </div>
  </div>
</section>
