---
import type { MotionPersonality } from '../motion/types';
import { motionConfigs } from '../motion/personalities';

interface Props {
  personality: MotionPersonality;
}

const { personality } = Astro.props;
const config = motionConfigs[personality];
---

<section class="py-32 px-8 md:px-16 lg:px-24">
  <div class="max-w-6xl mx-auto">
    <div
      class="cta-banner relative overflow-hidden p-16 md:p-24"
      style={`background-color: var(--color-ink); color: var(--color-paper)`}
    >
      <!-- アクセントライン -->
      <div
        class="absolute top-0 left-0 w-full h-px"
        style={`background-color: ${config.accentColor}`}
        aria-hidden="true"
      ></div>

      <!-- 装飾文字 -->
      <div
        class="absolute right-0 bottom-0 text-[15vw] leading-none font-bold select-none pointer-events-none"
        style="font-family: var(--font-display); opacity: 0.04; color: currentColor"
        aria-hidden="true"
      >
        {config.label}
      </div>

      <div class="relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-xs tracking-[0.25em] uppercase mb-4" style={`color: ${config.accentColor}`}>
            Contact
          </p>
          <h2 class="text-3xl md:text-4xl lg:text-5xl mb-6" style="font-family: var(--font-display)">
            まずは無料で<br />試してみる
          </h2>
          <p class="opacity-50 leading-relaxed">
            実際に動かして確かめてください。<br />モーションの違いは、言葉より体験が雄弁です。
          </p>
        </div>

        <div class="flex flex-col gap-4 lg:items-end">
          <button
            class="cta-btn relative inline-flex items-center gap-3 px-10 py-5 text-sm tracking-widest uppercase font-medium w-full lg:w-auto justify-center overflow-hidden"
            style={`background-color: ${config.accentColor}; color: ${config.textOnAccent}`}
          >
            <span
              class="btn-bg absolute inset-0"
              style="background-color: rgba(0,0,0,0.12); opacity: 0; transform-origin: left center"
            ></span>
            <span class="btn-label relative z-10">お問い合わせ</span>
            <span class="btn-arrow relative z-10 inline-block">→</span>
          </button>
          <p class="text-xs opacity-30 tracking-wider">無料プランあり・クレジットカード不要</p>
        </div>
      </div>
    </div>
  </div>
</section>
