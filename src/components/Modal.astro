---
import type { MotionPersonality } from '../motion/types';
import { motionConfigs } from '../motion/personalities';

interface Props {
  personality: MotionPersonality;
}

const { personality } = Astro.props;
const config = motionConfigs[personality];
---

<!-- モーダルオーバーレイ -->
<div
  class="modal-overlay fixed inset-0 z-50 flex items-center justify-center p-6 md:p-12"
  style="opacity: 0; pointer-events: none; background-color: rgba(0, 0, 0, 0.55)"
  role="dialog"
  aria-modal="true"
  aria-hidden="true"
>
  <div
    class="modal-content relative w-full max-w-xl bg-[var(--color-paper)] p-10 md:p-14 overflow-hidden"
    style="will-change: transform, opacity"
  >
    <!-- アクセントライン (上端) -->
    <div
      class="modal-line absolute top-0 left-0 h-0.5 w-0"
      style={`background-color: ${config.accentColor}`}
      aria-hidden="true"
    />

    <!-- 閉じるボタン -->
    <button
      class="modal-close absolute top-6 right-6 w-9 h-9 flex items-center justify-center border border-current/20 text-sm hover:border-current/50 transition-colors"
      aria-label="閉じる"
    >
      ✕
    </button>

    <!-- コンテンツ (JS で動的に注入) -->
    <div class="modal-body pt-4">
      <span
        class="modal-tag inline-block text-xs tracking-[0.2em] uppercase px-3 py-1 mb-6"
        style={`border: 1px solid ${config.accentColor}; color: ${config.accentColor}`}
      ></span>
      <h2
        class="modal-title text-2xl md:text-3xl mb-6 leading-snug"
        style="font-family: var(--font-display)"
      ></h2>
      <p class="modal-text text-sm leading-relaxed opacity-60"></p>

      <!-- 補足メトリクス -->
      <div class="mt-10 pt-8 border-t border-current/10">
        <p class="text-xs tracking-[0.2em] uppercase opacity-30 mb-5">関連指標</p>
        <div class="grid grid-cols-2 gap-6">
          <div>
            <p
              class="text-3xl font-mono mb-1"
              style={`color: ${config.accentColor}`}
            >
              +60%
            </p>
            <p class="text-xs opacity-40">パフォーマンス改善率</p>
          </div>
          <div>
            <p
              class="text-3xl font-mono mb-1"
              style={`color: ${config.accentColor}`}
            >
              ×1.8
            </p>
            <p class="text-xs opacity-40">滞在時間の倍率</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
